# ==========================================================================
# Exemplo de variáveis de ambiente. Copie para `.env` e ajuste os valores.
#   cp .env.example .env
# ==========================================================================

# --- Django ---
DJANGO_SECRET_KEY=troque-por-uma-chave-secreta-forte
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0
TIME_ZONE=America/Sao_Paulo
LOG_LEVEL=INFO

# --- PostgreSQL ---
# Banco já existente: desafio_tecnico
POSTGRES_DB=desafio_tecnico
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
# Local (sem Docker): localhost | Via docker-compose: db
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# --- JWT ---
JWT_ACCESS_MINUTES=60
JWT_REFRESH_DAYS=7

# --- Celery / Redis ---
# Local (sem Docker): redis://localhost:6379/0 | Via docker-compose: redis://redis:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1
# Intervalo (minutos) do cronjob de reposição de estoque
RESTOCK_INTERVAL_MINUTES=60

# --- IA / LLM (Gemini) ---
# Obtenha uma chave gratuita em https://aistudio.google.com/app/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
CONSULTOR_MAX_CANDIDATOS=25

# --- Integração externa (API Key) ---
INTEGRATION_API_KEY=defina-uma-api-key-forte-para-erp-wms
INTEGRATION_API_KEY_HEADER=X-API-KEY

# --- Canal WhatsApp (Evolution API) ---
# URL da sua instância Evolution (ex.: http://localhost:8080 ou http://evolution:8080 no Docker)
EVOLUTION_API_URL=
EVOLUTION_API_KEY=
EVOLUTION_INSTANCE=consultor
# Token que a Evolution deve enviar no header 'apikey' do webhook (autentica o webhook)
WHATSAPP_WEBHOOK_TOKEN=defina-um-token-forte-para-o-webhook

# --- Upload de CSV ---
IMPORT_MAX_FILE_SIZE=5242880
